# =============================================================================
# OpenHC — Docker Configuration
# Copy this file to .env.docker and adjust the values before running.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────

# Port exposed on the host machine
APP_PORT=8080

# Protocol used to access the app (http or https)
# This sets APP_URL inside the container.
# For HTTPS, terminate TLS at a reverse proxy (Nginx Proxy Manager, Caddy,
# Traefik…) in front of the container — the container itself always listens
# on plain HTTP internally.
APP_PROTOCOL=http

# Public hostname or IP (without protocol or port)
APP_DOMAIN=localhost

# ── Database ──────────────────────────────────────────────────────────────────

# Set COMPOSE_PROFILES to "with-db" to deploy a MariaDB container alongside
# the app. Leave it empty (or remove it) to connect to an external database.
# The database is NEVER exposed to the host — only the app container can
# reach it over the internal Docker network.
COMPOSE_PROFILES=with-db

# If COMPOSE_PROFILES=with-db, "db" resolves to the MariaDB container.
# For an external database, set DB_HOST to the actual hostname/IP.
DB_HOST=db
DB_PORT=3306

DB_DATABASE=openhc
DB_USERNAME=openhc
DB_PASSWORD=change_me_please
DB_ROOT_PASSWORD=change_root_password_too
